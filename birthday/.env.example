# ──────────────────────────────────────────────────────────────
# Darshita's Virtual Birthday — environment variables
# Copy to .env (root) / apps/web/.env.local as needed.
# NONE of these are required to run the M0 foundation shell — they are
# placeholders wired up in later milestones.
# ──────────────────────────────────────────────────────────────

# ── Web (apps/web) — exposed to the browser (NEXT_PUBLIC_*) ──
NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:2567   # realtime server (M3+)
NEXT_PUBLIC_SUPABASE_URL=                      # Supabase project URL (M5+)
NEXT_PUBLIC_SUPABASE_ANON_KEY=                 # Supabase anon key (M5+)

# ── Realtime server (apps/server) — secret, server-only ──
PORT=2567                                      # Colyseus listen port
SUPABASE_URL=                                  # Supabase project URL (M5+)
SUPABASE_SERVICE_ROLE_KEY=                     # secret service-role key (M5+)
REDIS_URL=                                     # scaling/presence coordination (M8)
SESSION_JWT_SECRET=                            # signs name-only guest sessions (M1/M3)
HOST_LINK_TOKEN=                               # secret host-link token (host powers)
