{
  "name": "darshita-virtual-birthday",
  "version": "0.0.0",
  "private": true,
  "description": "Darshita's Virtual Birthday — a cozy pixel-art multiplayer birthday venue.",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "assets:build": "node scripts/build-assets.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^15.1.3",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
